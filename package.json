{
  "name": "tiged",
  "version": "2.12.7",
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "Straightforward project scaffolding",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "module-sync": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "module": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "degit": "dist/bin.cjs",
    "tiged": "dist/bin.js"
  },
  "scripts": {
    "lint": "eslint --config=eslint.config.mjs --color .",
    "lint:fix": "eslint --config=eslint.config.mjs --color . --fix",
    "erase-ts-config-paths": "tsx scripts/eraseTSConfigPaths.mts",
    "format": "prettier --config=prettier.config.mjs --write .",
    "format:check": "prettier --config=prettier.config.mjs --check .",
    "clean": "tsx scripts/remove.mts",
    "build": "npm run clean && tsdown --config-loader=unrun --config=tsdown.config.mts",
    "test": "vitest --config=vitest.config.mts",
    "test-types": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiged/tiged.git"
  },
  "keywords": [
    "scaffolding",
    "template",
    "git"
  ],
  "author": "tiged",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tiged/tiged/issues"
  },
  "homepage": "https://github.com/tiged/tiged#readme",
  "dependencies": {
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.17",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rolldown": "^1.1.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "unrun": "^0.3.1",
    "vitest": "^4.1.9"
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "src/",
    "help.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
